package br.com.biblioteca.model;

import javax.persistence.*;
import java.util.List;

@Entity
@Table(name = "aluno")
public class Aluno {

    @Id
    @GeneratedValue(strategy = GenerationType.IDENTITY)
    private Long id;

    @Column(name = "matricula_aluno", unique = true, nullable = false)
    private Integer matriculaAluno;

    @Column(nullable = false, length = 100)
    private String nome;

    @OneToMany(mappedBy = "aluno")
    private List<Emprestimo> emprestimos;

    // getters e setters
    public Long getId() { return id; }
    public void setId(Long id) { this.id = id; }

    public Integer getMatriculaAluno() { return matriculaAluno; }
    public void setMatriculaAluno(Integer matriculaAluno) { this.matriculaAluno = matriculaAluno; }

    public String getNome() { return nome; }
    public void setNome(String nome) { this.nome = nome; }

    public List<Emprestimo> getEmprestimos() { return emprestimos; }
    public void setEmprestimos(List<Emprestimo> emprestimos) { this.emprestimos = emprestimos; }
}
